# Most setups only need this one value.
# The app already has sensible defaults for login endpoints, cookies, and other overrides.
# Do not put your GitHub or Copilot user token in .env; sign in through the browser flow instead.
COPILOT_ENVELOPE_SECRET=replace-with-long-random-secret

# Optional only if you want a different default model.
# DEFAULT_MODEL=gpt-5.4